# ============================================================
#  קובץ דוגמה למשתני סביבה — צוות הסוכנים של ראובן
# ------------------------------------------------------------
#  העתיקו קובץ זה ל-.env ומלאו את הערכים האמיתיים.
#  אל תכניסו ערכים אמיתיים לקובץ הזה — הוא נכנס ל-git.
# ============================================================

# --- Anthropic (המנוע של הסוכנים) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- יובל — מעצב התמונות (OpenAI Images API, מודל gpt-image-2) ---
#     משמש את הסקיל gpt-image-gen ליצירת תמונות.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- חן — חוקרת (חיפוש מידע) ---
# SEARCH_API_KEY=

# --- כללי ---
# סביבת ריצה: development | production
APP_ENV=development
